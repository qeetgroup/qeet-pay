# =============================================================================
# Qeet Pay — environment template
# =============================================================================
# Copy to `.env` for local dev (`cp .env.example .env`). The dev profile boots
# without Qeet ID (see platform/security/SecurityConfig) and every value below
# has a working local default in application.yml — the uncommented block is all
# you need for `make db-up && make dev`.
#
# NEVER commit a real `.env`. It is gitignored. Secrets in production come from
# AWS Secrets Manager / KMS, injected as env vars — not from a file in the repo.
# See SECURITY.md ("Secure configuration") and TAD §14 (Secrets/keys).
#
# Commented keys below are OFF/placeholder by design: unset live-adapter keys
# fall back to the built-in sandbox adapters (@ConditionalOnMissingBean), so the
# stack runs end-to-end with zero third-party credentials.
# =============================================================================


# --- Core / runtime ----------------------------------------------------------
SERVER_PORT=4201
# dev | test | staging | prod. dev/test are permissive (accept X-Merchant-Id);
# staging/prod require Qeet ID OIDC + qp_live_/qp_test_ API keys.
SPRING_PROFILES_ACTIVE=dev
# root log level: error|warn|info|debug|trace
LOG_LEVEL=info


# --- Database (Postgres 17) ---------------------------------------------------
# docker-compose maps host 5201 -> container 5432. `qeet_pay` is the dev role.
DATABASE_URL=jdbc:postgresql://localhost:5201/qeet_pay
DATABASE_USER=qeet_pay
DATABASE_PASSWORD=qeet_pay
# PROD ONLY: connect as the NOSUPERUSER `qeet_pay_app` role (created in V2).
# RLS is bypassed by superusers/table owners, so the app MUST NOT run as one in
# prod (see CLAUDE.md Gotchas + SECURITY.md). The dev docker-compose user is a
# superuser and is intentionally NOT tenant-scoped.
# DATABASE_USER=qeet_pay_app
# DATABASE_PASSWORD=__from_secrets_manager__


# --- Identity — Qeet ID OIDC relying party (TAD §2.2) -------------------------
# Only enforced by the non-dev profiles. Programmatic /v1 calls use API keys
# (X-Api-Key: qp_live_… / qp_test_…); interactive callers use Qeet ID JWTs.
QEETID_ISSUER_URI=https://api.id.qeet.in
QEETID_JWKS_URI=https://api.id.qeet.in/.well-known/jwks.json


# --- API / CORS ---------------------------------------------------------------
# Comma-separated origins allowed to call the API (the console runs on :3201).
ALLOWED_ORIGINS=http://localhost:3201


# --- Eventing — transactional outbox relay to NATS (TAD §9.1, §9.5) -----------
# Off by default: events are written to platform.outbox_event in-transaction; the
# NatsEventRelay drains them to pay.{merchant_id}.events.{type} only when enabled.
QEETPAY_NATS_ENABLED=false
NATS_URL=nats://localhost:4222


# --- Fraud scoring — Python fraud-svc (TAD §8) --------------------------------
# Off by default -> allow-all. When enabled, scores route through the FastAPI svc.
QEETPAY_FRAUD_ENABLED=false
FRAUD_SVC_URL=http://localhost:8201


# --- Cache / velocity store — Redis (reserved) --------------------------------
# Reserved for idempotency-key acceleration and fraud velocity (TAD §12.4, §13).
# NOTE: the /v1 rate limiter is an in-memory token bucket (no Redis dependency),
# so Redis is optional; wire it here when the velocity/cache features land.
REDIS_URL=redis://localhost:6379


# --- Observability — OpenTelemetry + tracing (TAD §12.3) ----------------------
# OTLP trace export is OFF by default (no-op). Prometheus metrics are ALWAYS
# exposed at /actuator/prometheus (see application.yml). Keys match application.yml.
QEETPAY_OTEL_ENABLED=false
QEETPAY_OTLP_ENDPOINT=http://localhost:4318/v1/traces   # qeet-logs OTLP target when enabled
# Fraction of requests traced (0.0–1.0). Keep low in prod; 1.0 only for debug.
QEETPAY_TRACING_SAMPLE_RATE=0.1


# --- Rate limiting (TAD §12.4) ------------------------------------------------
# Enablement is PROFILE-DRIVEN (off in dev/test; ON in the prod & staging profiles
# in application.yml) — there is no on/off env var. These two tune the token bucket:
QEETPAY_RATELIMIT_CAPACITY=120              # burst size per caller
QEETPAY_RATELIMIT_REFILL_PER_SECOND=50      # sustained requests/sec per caller


# --- Payment provider — Razorpay (Phase-1 sub-merchant acquiring) -------------
# Off by default -> the sandbox payment adapter is used. Set live keys only in
# staging/prod, sourced from Secrets Manager. NEVER commit real keys.
QEETPAY_RAZORPAY_ENABLED=false
QEETPAY_RAZORPAY_KEY_ID=
QEETPAY_RAZORPAY_KEY_SECRET=
QEETPAY_RAZORPAY_WEBHOOK_SECRET=


# --- Live external adapters (default to built-in sandbox when unset) ----------
# Each external backend uses the sandbox-adapter pattern; leave *_ENABLED=false
# (or unset) to run against the deterministic in-process sandbox. Flip to true
# and supply credentials (from Secrets Manager) to hit the real vendor.
#
# GSTN / IRP — GST return filing (filing/) + IRN e-invoicing (gst/)
# QEETPAY_GSTN_ENABLED=false
# QEETPAY_GSTN_BASE_URL=
# QEETPAY_GSTN_API_KEY=
# QEETPAY_IRP_ENABLED=false
# QEETPAY_IRP_BASE_URL=
# QEETPAY_IRP_CLIENT_ID=
# QEETPAY_IRP_CLIENT_SECRET=
#
# AA (Account Aggregator) — lending/ underwriting data pulls
# QEETPAY_AA_ENABLED=false
# QEETPAY_AA_BASE_URL=
# QEETPAY_AA_CLIENT_ID=
# QEETPAY_AA_CLIENT_SECRET=
#
# FX — crossborder/ inward-remittance rate + FIRA
# QEETPAY_FX_ENABLED=false
# QEETPAY_FX_BASE_URL=
# QEETPAY_FX_API_KEY=
#
# KYB — merchants/ onboarding verification
# QEETPAY_KYB_ENABLED=false
# QEETPAY_KYB_BASE_URL=
# QEETPAY_KYB_API_KEY=
