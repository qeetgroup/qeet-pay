# Copy to .env for local dev. The dev profile boots without Qeet ID (see SecurityConfig).
SERVER_PORT=4201
SPRING_PROFILES_ACTIVE=dev

# Postgres (docker-compose maps host 5201 -> container 5432). qeet_pay is the dev role.
DATABASE_URL=jdbc:postgresql://localhost:5201/qeet_pay
DATABASE_USER=qeet_pay
DATABASE_PASSWORD=qeet_pay

# Qeet ID OIDC relying-party (TAD §2.2). Only used by the non-dev profiles.
QEETID_ISSUER_URI=https://api.id.qeet.in
QEETID_JWKS_URI=https://api.id.qeet.in/.well-known/jwks.json

# CORS for the (future) console
ALLOWED_ORIGINS=http://localhost:3201

# Eventing — transactional outbox relay to NATS (off by default; TAD §9.1)
QEETPAY_NATS_ENABLED=false
NATS_URL=nats://localhost:4222

# Fraud scoring — Python fraud-svc on :8201 (off by default → allow-all; TAD §8)
QEETPAY_FRAUD_ENABLED=false
FRAUD_SVC_URL=http://localhost:8201
