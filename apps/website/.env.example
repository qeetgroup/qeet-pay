# Public build-time config for the Qeet Pay marketing site (pay.qeet.in).
# Next inlines NEXT_PUBLIC_* at build; only public values belong here (no
# secrets). The marketing site never calls the backend API directly — it links
# out to the operator console (sign in / start), the docs, and the API portal.

# Canonical / OG base URL for this site.
NEXT_PUBLIC_SITE_URL=https://pay.qeet.in

# Operator console the "Sign in" / "Start free" links point to.
# Local dev: http://localhost:3201
NEXT_PUBLIC_CONSOLE_URL=http://localhost:3201

# Product documentation (docs.qeet.in/pay).
NEXT_PUBLIC_DOCS_URL=https://docs.qeet.in/pay

# Developer / API portal (apis.qeet.in).
NEXT_PUBLIC_API_URL=https://apis.qeet.in
